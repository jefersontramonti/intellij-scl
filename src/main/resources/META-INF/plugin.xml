<!-- ─────────────────────────────────────────────────────────────────────────
     plugin.xml — Manifesto do plugin SCL Language Support
     Extension points verificados em:
     https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html
     ───────────────────────────────────────────────────────────────────────── -->
<idea-plugin>

    <id>com.scl.plugin.scl-language-support</id>
    <name>SCL Language Support</name>
    <vendor>SCL Plugin</vendor>

    <description><![CDATA[
        Full language support for SCL (Structured Control Language) —
        Siemens TIA Portal V19 / STEP 7 S7-300/400.<br/><br/>
        <b>Phase 1 — Foundation:</b>
        <ul>
          <li>Syntax highlighting for all SCL tokens</li>
          <li>.scl / .SCL file type recognition</li>
          <li>Line (//) and block (* … *) comments</li>
          <li>Siemens memory access highlighting (%MW, %I, %Q)</li>
        </ul>
        <b>Phase 2 — Parser &amp; Editor Basics:</b>
        <ul>
          <li>Full BNF grammar (Grammar-Kit) with complete PSI tree</li>
          <li>Code folding: blocks, var sections, IF/FOR/WHILE/REGION/CONST</li>
          <li>Commenter: Ctrl+/ for // and Ctrl+Shift+/ for (* … *)</li>
        </ul>
        <b>Phase 3 — Completion &amp; Templates:</b>
        <ul>
          <li>Keyword / type / constant completion (Ctrl+Space)</li>
          <li>10 live templates: if, ife, case, for, while, repeat, fb, var, region, ton</li>
          <li>Color settings page: Settings → Editor → Color Scheme → SCL</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ── File type ──────────────────────────────────────────────────
             fieldName="INSTANCE" e obrigatorio — referencia o campo estatico
             gerado automaticamente pelo Kotlin object SclFileType.
             ──────────────────────────────────────────────────────────── -->
        <fileType
            name="SCL File"
            implementationClass="com.scl.plugin.language.SclFileType"
            fieldName="INSTANCE"
            language="SCL"
            extensions="scl;SCL"/>

        <!-- ── Parser Definition ─────────────────────────────────────────
             Conecta Language → Lexer → Parser → PSI.
             ──────────────────────────────────────────────────────────── -->
        <lang.parserDefinition
            language="SCL"
            implementationClass="com.scl.plugin.parser.SclParserDefinition"/>

        <!-- ── Syntax Highlighting ───────────────────────────────────────
             SyntaxHighlighterFactory e o padrao para 2023.1+.
             ──────────────────────────────────────────────────────────── -->
        <lang.syntaxHighlighterFactory
            language="SCL"
            implementationClass="com.scl.plugin.highlighting.SclSyntaxHighlighterFactory"/>

        <!-- ── Color Settings Page ───────────────────────────────────────
             Settings → Editor → Color Scheme → SCL
             ──────────────────────────────────────────────────────────── -->
        <colorSettingsPage
            implementation="com.scl.plugin.highlighting.SclColorSettingsPage"/>

        <!-- ── Code Folding ──────────────────────────────────────────────
             Recolhe blocos, var sections, IF/FOR/WHILE/CASE/REGION/CONST.
             ──────────────────────────────────────────────────────────── -->
        <lang.foldingBuilder
            language="SCL"
            implementationClass="com.scl.plugin.folding.SclFoldingBuilder"/>

        <!-- ── Commenter ─────────────────────────────────────────────────
             Ctrl+/ para linha (//), Ctrl+Shift+/ para bloco (* *).
             ──────────────────────────────────────────────────────────── -->
        <lang.commenter
            language="SCL"
            implementationClass="com.scl.plugin.SclCommenter"/>

        <!-- ── Brace Matcher ─────────────────────────────────────────────
             Destaca pares estruturais ao clicar: FUNCTION_BLOCK <-> END_FUNCTION_BLOCK,
             IF <-> END_IF, VAR_* <-> END_VAR, etc.
             structural=true: ativa navegacao Ctrl+Shift+M entre pares.
             ──────────────────────────────────────────────────────────── -->
        <lang.braceMatcher
            language="SCL"
            implementationClass="com.scl.plugin.SclBraceMatcher"/>

        <!-- ── Parameter Info ────────────────────────────────────────────
             Popup de assinatura ao digitar `(` apos nome de builtin Siemens.
             Ex: TON -> "IN: BOOL :=, PT: TIME :=, Q: BOOL =>, ET: TIME =>"
             Ativacao manual: Ctrl+P (Windows/Linux) ou Cmd+P (macOS).
             ──────────────────────────────────────────────────────────── -->
        <codeInsight.parameterInfo
            language="SCL"
            implementationClass="com.scl.plugin.completion.SclParameterInfoHandler"
            dumbAware="true"/>

        <!-- ── Completion Contributor ────────────────────────────────────
             Palavras-chave, tipos, constantes em qualquer posicao SCL.
             Fase 4A: builtins com template de chamada + nomes de parametros.
             dumbAware="true": funciona durante indexacao do projeto.
             ──────────────────────────────────────────────────────────── -->
        <completion.contributor
            language="SCL"
            implementationClass="com.scl.plugin.completion.SclCompletionContributor"
            order="first"/>

        <!-- ── Completion Confidence ─────────────────────────────────────
             Activa o auto-popup enquanto o usuario digita em arquivos SCL.
             Sem este componente, o IntelliJ suprime o popup automatico em
             linguagens customizadas (digitar s_, i_, #var nao abre popup).
             ──────────────────────────────────────────────────────────── -->
        <completion.confidence
            language="SCL"
            implementationClass="com.scl.plugin.completion.SclCompletionConfidence"
            order="first"/>

        <!-- ── Live Template Context ─────────────────────────────────────
             Ativa os templates de SCL.xml em arquivos .scl.
             contextId deve coincidir com o ID em SclTemplateContext.
             ──────────────────────────────────────────────────────────── -->
        <liveTemplateContext
            implementation="com.scl.plugin.completion.SclTemplateContext"
            contextId="SCL"/>

        <!-- ── Live Templates ────────────────────────────────────────────
             if, ife, case, for, while, repeat, fb, var, region, ton.
             ──────────────────────────────────────────────────────────── -->
        <defaultLiveTemplates file="/liveTemplates/SCL.xml"/>

        <!-- ── Fase 4: Hardware Target — serviço de projeto ────────────────────
             Persiste S7-1200 / S7-1500 em .idea/sclHardwareTarget.xml.
             ──────────────────────────────────────────────────────────── -->
        <projectService
            serviceImplementation="com.scl.plugin.linter.SclHardwareTargetService"/>

        <!-- ── Fase 4: Hardware Target — widget na status bar ───────────────
             Exibe "SCL: S7-1200" / "SCL: S7-1500"; clique troca o target.
             ──────────────────────────────────────────────────────────── -->
        <statusBarWidgetFactory
            implementation="com.scl.plugin.linter.SclHardwareStatusBarWidgetFactory"
            id="SclHardwareTarget"/>

        <!-- ── Fase 4: Linter HW-Aware ───────────────────────────────────────
             LocalInspectionTool (preferível a lang.annotator para linters
             de linguagens customizadas no IntelliJ Platform 2024+).
             Aparece em Settings → Editor → Inspections → SCL.
             5 regras:
               1. TIME_TO_DINT → ERROR no S7-1200
               2. LREAL        → WARNING no S7-1200 (quick fix: → REAL)
               3. %Mx conflito → ERROR (ambos HW)
               4. Blink bug    → WARNING (ambos HW)
               5. CASE deadlock → WARNING (ambos HW)
             ──────────────────────────────────────────────────────────── -->
        <localInspection
            language="SCL"
            shortName="SclHardwareCompatibility"
            displayName="SCL Hardware Compatibility"
            groupName="SCL"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="com.scl.plugin.linter.SclHardwareLinter"/>

        <!-- ── Hover Documentation (API moderna 2023.1+) ─────────────────────
             Exibe tooltip ao passar o mouse sobre variáveis SCL declaradas.
             Formato hover rapido: "nome — comentario: TIPO  [SECAO]"
             Formato completo (Ctrl+Q): HTML com Type, Section, Block, Default.
             Usa targetProvider (offset-based) em vez de psiTargetProvider para
             evitar problemas de PSI element matching com Grammar-Kit leaf tokens.
             NAO usar lang.documentationProvider (deprecated).
             ──────────────────────────────────────────────────────────── -->
        <platform.backend.documentation.targetProvider
            implementation="com.scl.plugin.documentation.SclDocumentationTargetProvider"/>

        <!-- ── Structure View (Alt+7) ───────────────────────────────────────────
             Painel lateral com hierarquia do arquivo SCL:
             Arquivo → FB/FC/OB/TYPE → VAR_INPUT/VAR_OUTPUT/… → variáveis.
             Clicar em qualquer nó navega para a declaração no editor.
             ──────────────────────────────────────────────────────────── -->
        <lang.psiStructureViewFactory
            language="SCL"
            implementationClass="com.scl.plugin.structure.SclStructureViewFactory"/>

        <!-- ── Code Style Settings Providers ───────────────────────────────
             Dois EPs são necessários:
             1. codeStyleSettingsProvider → alimenta o CustomCodeStyleSettingsManager
                (sem ele, getCustomSettings() lança RuntimeException)
             2. langCodeStyleSettingsProvider → UI de Code Style + getCodeSample()
             ──────────────────────────────────────────────────────────── -->
        <codeStyleSettingsProvider
            implementation="com.scl.plugin.formatting.SclCodeStyleSettingsProvider"/>
        <langCodeStyleSettingsProvider
            implementation="com.scl.plugin.formatting.SclLanguageCodeStyleSettingsProvider"/>

        <!-- ── Formatter (Ctrl+Alt+L) ────────────────────────────────────────
             FormattingModelBuilder que delega indentação ao SclBlock e
             espaçamento ao SclSpacingBuilder.
             ──────────────────────────────────────────────────────────── -->
        <lang.formatter
            language="SCL"
            implementationClass="com.scl.plugin.formatting.SclFormattingModelBuilder"/>

    </extensions>

</idea-plugin>
