FUNCTION_BLOCK "F_SafetyTest"
(*
 * Company: JT Automação
 * (c) Copyright 2026
 * ─────────────────────────────────────────────────
 * Title:            F_SafetyTest
 * Function:         Safety plugin test block — covers all linter rules
 * Library/Family:   Safety / Test
 * Author:           Test
 * Tested with:      TIA Portal V19 / STEP 7 Safety V21
 * Engineering:      S7-1200F FW V4.x
 * Safety Level:     SIL 2 / PL d Cat 3
 * Restrictions:     FOR PLUGIN TESTING ONLY — not for production use
 * Requirements:     STEP 7 Safety Advanced
 * ─────────────────────────────────────────────────
 * Change log:
 * Version | Date       | Author    | Changes
 * --------|------------|-----------|------------------
 * 01.00   | 2026-04-01 | JT        | First release
 * ─────────────────────────────────────────────────
 * F-Signature: [generated by TIA Portal after acceptance]
*)

// =========================================================================
// SEÇÃO 1 — Interface válida em Safety
// Tipos PERMITIDOS: Bool, Byte, Word, DWord, Int, DInt, UInt, UDInt, Real
// =========================================================================

VAR_INPUT
    // ✅ Tipos válidos em Safety
    i_EStopCh1   : Bool;   // Canal 1 E-Stop NF
    i_EStopCh2   : Bool;   // Canal 2 E-Stop redundância
    i_GuardDoor  : Bool;   // Porta de segurança NF
    i_AckButton  : Bool;   // Botão reconhecimento
    i_OpMode     : Int;    // Modo operação: 0=Auto 1=Manual 2=Service
    i_ProcessVal : Real;   // Valor de processo

    // ❌ DEVE gerar ERRO — tipos proibidos em Safety:
    i_LIntVal    : LInt;   // ERRO: LInt não suportado em Safety
    i_LWordVal   : LWord;  // ERRO: LWord não suportado em Safety
    i_LTimeVal   : LTime;  // ERRO: LTime não suportado em Safety
    i_LRealVal   : LReal;  // AVISO: LReal — verificar suporte na CPU
    i_WStrVal    : WString; // ERRO: WString não suportado em Safety
END_VAR

VAR_OUTPUT
    o_SafetyRelease  : Bool;   // TRUE = seguro para operar
    o_DriveEnable    : Bool;   // Habilita acionamento
    o_DiagCode       : Int;    // Código de diagnóstico
    o_State          : Int;    // Estado atual da FSM
END_VAR

VAR
    // ✅ Instâncias válidas em Safety
    s_AckEdge    : R_TRIG;   // Borda subida do reconhecimento
    s_State      : Int;       // Estado FSM de segurança
    s_AckPending : Bool;      // Reconhecimento pendente

    // Timer — usar com moderação em Safety (Guideline §4.1.2)
    s_MonTimer   : TON;       // Timer de monitoração
END_VAR

VAR_TEMP
    t_AllSafe    : Bool;   // Resultado AND de todas as funções
    t_Index      : Int;    // Índice auxiliar
END_VAR

BEGIN

// =========================================================================
// SEÇÃO 2 — Edge detection (✅ correto em Safety)
// =========================================================================

REGION Edge Detection
    s_AckEdge(CLK := i_AckButton);
END_REGION

// =========================================================================
// SEÇÃO 3 — Lógica de segurança correta (AND/OR simples)
// Guideline §3.4: use principalmente AND e OR
// =========================================================================

REGION Safety Logic — Level 1 (always active)
    // ✅ Correto — lógica AND simples conforme Guideline §3.4
    t_AllSafe := i_EStopCh1
             AND i_EStopCh2
             AND i_GuardDoor;
END_REGION

// =========================================================================
// SEÇÃO 4 — State machine (✅ recomendado em Safety)
// Guideline §4.1.1: use state machines em vez de GOTO
// =========================================================================

REGION State Machine
    CASE s_State OF

        0: // SAFE_STATE — estado seguro inicial
            o_SafetyRelease := FALSE;
            o_DriveEnable   := FALSE;
            s_AckPending    := NOT t_AllSafe;

            // Transição para RUNNING apenas se tudo seguro
            // e botão de reconhecimento pressionado
            IF t_AllSafe AND s_AckEdge.Q THEN
                s_State := 1;
            END_IF;

        1: // RUNNING — operação normal
            o_SafetyRelease := TRUE;

            // Modo automático: habilita acionamento
            IF i_OpMode = 0 THEN
                o_DriveEnable := TRUE;
            ELSE
                o_DriveEnable := FALSE;
            END_IF;

            // Qualquer falha → volta ao estado seguro
            IF NOT t_AllSafe THEN
                s_State     := 0;
                o_DiagCode  := 1001;
            END_IF;

        2: // FAULT — falha ativa
            o_SafetyRelease := FALSE;
            o_DriveEnable   := FALSE;

            // Reset apenas com reconhecimento e condições seguras
            IF s_AckEdge.Q AND t_AllSafe THEN
                s_State    := 0;
                o_DiagCode := 0;
            END_IF;

        // ✅ ELSE obrigatório em Safety — retorna ao estado seguro
        ELSE
            s_State    := 0;
            o_DiagCode := 9999;  // Estado desconhecido

    END_CASE;
END_REGION

// =========================================================================
// SEÇÃO 5 — Timer (✅ uso moderado conforme Guideline §4.1.2)
// =========================================================================

REGION Monitoring Timer
    s_MonTimer(
        IN := o_SafetyRelease,
        PT := T#30S
    );

    // Timeout de monitoração
    IF s_MonTimer.Q THEN
        s_State    := 2;
        o_DiagCode := 2001;
    END_IF;
END_REGION

// =========================================================================
// SEÇÃO 6 — ERROS INTENCIONAIS PARA TESTAR O LINTER
// As linhas abaixo DEVEM gerar avisos/erros no plugin
// =========================================================================

REGION Linter Test — Intentional Errors

    // ❌ DEVE gerar ERRO — GOTO proibido em Safety:
    // Guideline §4.1.1: "Avoid jumps in the safety program"
    GOTO myLabel;       // ERRO: GOTO é proibido em Safety

    // ❌ DEVE gerar ERRO — acesso a dados globais em F-FB:
    // Guideline §3.6: "Connect global data only in Main Safety"
    "DB_Global".SystemReady := TRUE;  // ERRO: acesso global em F-FB

    // ❌ Label (consequência do GOTO acima)
    myLabel:
    t_Index := 0;


    // ⚠️ DEVE gerar WARNING — EXIT em loop (jump):
    FOR t_Index := 0 TO 10 DO
        IF t_Index = 5 THEN
            EXIT;   // WARNING: jumps devem ser minimizados em Safety
        END_IF;
    END_FOR;

    // ⚠️ DEVE gerar WARNING — acesso a F-I/O sem value status:
    // Correto seria: i_EStopCh1 AND "DI_Safety".EStop_Ch1_VS
    t_AllSafe := "DI_Safety".EStop_Ch1;  // WARNING: sem verificação _VS

END_REGION

// =========================================================================
// SEÇÃO 7 — Output Assignment (✅ sempre no final)
// =========================================================================

REGION Output Assignment
    o_State := s_State;
END_REGION

END_FUNCTION_BLOCK
