FUNCTION_BLOCK "FB_TimerControl"
{ S7_Optimized_Access := 'TRUE' }
//=============================================================
// FB_TimerControl — Display de Tempo Decorrido (%QD38)
// Projeto : 3 – Filling Tank (Timers)
// Rev     : 1.0 | 2026-04-02
//
// Recebe o tempo decorrido de FB_TankControl e o encaminha
// para o display %QD38 (DInt, segundos).
// Exibe 0 quando o sistema não está em ciclo ativo.
//
// Estados com display ativo: 1=STARTING, 4=TIMER_CTRL
//=============================================================

VAR_INPUT
    i_TimerElapsed : DInt;   // Segundos decorridos (FB_TankControl.o_TimerElapsed)
    i_State : Int;    // Estado FSM atual (FB_TankControl.o_State)
END_VAR

VAR_OUTPUT
    o_TimerDisplay : DInt;   // %QD38 — display timer (segundos inteiros)
END_VAR

BEGIN
//==========================================================
// Encaminha tempo decorrido para o display apenas nos
// estados onde um timer está activo (STARTING e TIMER_CTRL).
// Nos demais estados, exibe 0 (display apagado / zerado).
//==========================================================
    IF (i_State = 1) OR (i_State = 4) THEN
        o_TimerDisplay := i_TimerElapsed;
    ELSE
        o_TimerDisplay := 0;
    END_IF;

END_FUNCTION_BLOCK
