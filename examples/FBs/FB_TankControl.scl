FUNCTION_BLOCK "FB_TankControl"
{ S7_Optimized_Access := 'TRUE' }
//=============================================================
// FB_TankControl — Filling Tank FSM
// Projeto : 3 – Filling Tank (Timers)
// Rev     : 1.0 | 2026-04-02
// Estados : 0=IDLE  1=STARTING  2=FILLING  3=DRAINING
//           4=TIMER_CTRL  5=HOLDING  98=FAULT  99=EMERGENCY
//=============================================================

VAR_INPUT
    i_EStop         : Bool;             // NF: TRUE=seguro, FALSE=emergência (%I0.3)
    i_Start         : Bool;             // Botão Start (%I0.5)
    i_Stop          : Bool;             // Botão Stop  (%I0.6)
    i_FaultReset    : Bool;             // Botão Reset (%I0.4)
    i_LevelMeter    : Real;             // Nível tanque (%ID34)  0–10 m
    i_FlowMeter     : Real;             // Fluxo (%ID30)          0–10 m³/h
    i_PotFill       : Real;             // POT EncheTanque (%ID38) 0–10
    i_PotDrain      : Real;             // POT EsvaziaTanque (%ID42) 0–10
    i_TimerMode     : Bool;             // TRUE = modo timer, FALSE = manual
    i_FillTime      : Time := T#30S;    // Tempo de enchimento (TIMER_CTRL)
    i_DrainTime     : Time := T#20S;    // Tempo de esvaziamento (TIMER_CTRL)
    i_LevelHiLimit  : Real := 9.5;      // Limite máximo de nível
    i_LevelLoLimit  : Real := 0.2;      // Limite mínimo de nível
END_VAR

VAR_OUTPUT
    o_FillValve     : Real;             // Válvula enchimento (%QD34) 0–10
    o_DrainValve    : Real;             // Válvula descarga   (%QD30) 0–10
    o_State         : Int;              // Estado FSM atual
    o_FaultCode     : Int;              // Código de falha ativo
    o_IsRunning     : Bool;             // TRUE em FILLING ou TIMER_CTRL
    o_IsFault       : Bool;             // TRUE em FAULT ou EMERGENCY
    o_TimerElapsed  : DInt;             // Segundos decorridos (para display)
    o_CycleCount    : DInt;             // Ciclos completos desde reset
END_VAR

VAR
    s_State         : Int  := 0;        // Estado FSM corrente
    s_FaultCode     : Int  := 0;        // Código de falha corrente
    s_CycleCount    : DInt := 0;        // Contador de ciclos completos
    s_TimerPhase    : Int  := 0;        // Fase TIMER_CTRL: 0=fill / 1=drain
    s_LevelHiLatch  : Bool;             // Latch nível alto (histerese)
    s_LevelLoLatch  : Bool;             // Latch nível baixo (histerese)
    s_StartEdge     : R_TRIG;           // Detecção borda botão Start
    s_StopEdge      : R_TRIG;           // Detecção borda botão Stop
    s_ResetEdge     : R_TRIG;           // Detecção borda botão Reset
    s_StartingTimer : TON;              // Delay pré-partida (1 s)
    s_FlowWatchdog  : TON;              // Watchdog fluxo (10 s)
    s_FillTimer     : TON;              // Timer enchimento em TIMER_CTRL
    s_DrainTimer    : TON;              // Timer drenagem em TIMER_CTRL
    testVal : LREAL;
END_VAR

VAR_TEMP
    t_FillOut       : Real;             // Saída calculada válvula fill
    t_DrainOut      : Real;             // Saída calculada válvula drain
END_VAR

BEGIN
    //==========================================================
    // PRIORIDADE 0 — E-STOP NF
    // Avaliado ANTES de qualquer lógica de controle
    // NF: %I0.3 = FALSE → emergência
    //==========================================================
    IF NOT i_EStop THEN
        s_State     := 99;
        s_FaultCode := 9800;
    END_IF;

    s_DrainTimer.Q := FALSE;
    s_FillTimer.Q  := FALSE;


    //==========================================================
    // DETECÇÃO DE BORDA — botões (R_TRIG: dispara na subida)
    //==========================================================
    s_StartEdge(CLK := i_Start);
    s_StopEdge(CLK  := i_Stop);
    s_ResetEdge(CLK := i_FaultReset);

    //==========================================================
    // PROTEÇÃO DE NÍVEL COM HISTERESE (0.3 m)
    // High latch: ON >= HiLimit  | OFF < (HiLimit - 0.3)
    // Low  latch: ON <= LoLimit  | OFF > (LoLimit + 0.3)
    //==========================================================
    IF i_LevelMeter >= i_LevelHiLimit THEN
        s_LevelHiLatch := TRUE;
    ELSIF i_LevelMeter < (i_LevelHiLimit - 0.3) THEN
        s_LevelHiLatch := FALSE;
    END_IF;

    IF i_LevelMeter <= i_LevelLoLimit THEN
        s_LevelLoLatch := TRUE;
    ELSIF i_LevelMeter > (i_LevelLoLimit + 0.3) THEN
        s_LevelLoLatch := FALSE;
    END_IF;

    //==========================================================
    // TIMERS — IN baseado no estado/fase atual (self-managing)
    //==========================================================
    s_StartingTimer(
        IN := (s_State = 1),
        PT := T#1S
    );
    s_FillTimer(
        IN := (s_State = 4) AND (s_TimerPhase = 0),
        PT := i_FillTime
    );
    s_DrainTimer(
        IN := (s_State = 4) AND (s_TimerPhase = 1),
        PT := i_DrainTime
    );

    //==========================================================
    // FSM — inicializa saídas temporárias
    //==========================================================
    t_FillOut  := 0.0;
    t_DrainOut := 0.0;

    CASE s_State OF

        //------------------------------------------------------
        0: // IDLE — sistema parado, válvulas fechadas
        //------------------------------------------------------
            IF s_StartEdge.Q THEN
                s_State := 1;           // → STARTING
            END_IF;

        //------------------------------------------------------
        1: // STARTING — pré-partida com delay de 1 s
        //------------------------------------------------------
            IF s_StartingTimer.Q THEN
                IF s_LevelHiLatch THEN
                    s_FaultCode := 2001;
                    s_State     := 98;  // Nível já no limite → FAULT
                ELSIF i_TimerMode THEN
                    s_TimerPhase := 0;
                    s_State      := 4;  // → TIMER_CTRL
                ELSE
                    s_State := 2;       // → FILLING (modo manual)
                END_IF;
            END_IF;
            IF s_StopEdge.Q THEN
                s_State := 0;           // Start cancelado → IDLE
            END_IF;

        //------------------------------------------------------
        2: // FILLING — enchimento via potenciômetro
        //------------------------------------------------------
            t_FillOut := i_PotFill;
            IF s_LevelHiLatch THEN
                t_FillOut   := 0.0;
                s_FaultCode := 2001;
                s_State     := 98; // Nível máximo → FAULT
            ELSIF s_StopEdge.Q THEN
                s_State := 3; // Stop → DRAINING
            END_IF;

        //------------------------------------------------------
        3: // DRAINING — drenagem via potenciômetro
        //------------------------------------------------------
            t_DrainOut := i_PotDrain;
            IF s_LevelLoLatch THEN
                t_DrainOut   := 0.0;
                s_CycleCount := s_CycleCount + 1;
                s_State      := 0;      // Nível mínimo → IDLE + conta ciclo
            ELSIF s_StopEdge.Q THEN
                s_State := 0;           // Stop durante dreno → IDLE
            END_IF;

        //------------------------------------------------------
        4: // TIMER_CTRL — ciclo por tempo (fill → drain → IDLE)
        //------------------------------------------------------
            CASE s_TimerPhase OF

                0: // Fase enchimento
                    t_FillOut := i_PotFill;
                    IF s_LevelHiLatch THEN
                        t_FillOut   := 0.0;
                        s_FaultCode := 2001;
                        s_State     := 98;
                    ELSIF s_FillTimer.Q THEN
                        s_TimerPhase := 1;  // Fill concluído → fase drain
                    END_IF;

                1: // Fase drenagem
                    t_DrainOut := i_PotDrain;
                    IF s_DrainTimer.Q OR s_LevelLoLatch THEN
                        t_DrainOut   := 0.0;
                        s_CycleCount := s_CycleCount + 1;
                        s_TimerPhase := 0;
                        s_State      := 0;  // Ciclo completo → IDLE
                    END_IF;

                ELSE
                    s_TimerPhase := 0;

            END_CASE;

            IF s_StopEdge.Q THEN
                s_TimerPhase := 0;
                s_State      := 3;     // Stop → DRAINING (esvazia antes)

            END_IF;
        //------------------------------------------------------
        98: // FAULT — válvulas fechadas, aguarda reset
        //------------------------------------------------------
            IF s_ResetEdge.Q AND i_EStop THEN
                s_FaultCode := 0;
                s_State     := 0;       // Reset aceito → IDLE
            END_IF;

        //------------------------------------------------------
        99: // EMERGENCY — E-Stop NF ativo
        //------------------------------------------------------
            IF i_EStop THEN             // E-Stop liberado
                s_State := 98;          // → FAULT (exige reset manual)
            END_IF;

        //------------------------------------------------------
        ELSE
            s_FaultCode := 9999;        // Estado desconhecido
            s_State     := 98;

    END_CASE;

    //==========================================================
    // WATCHDOG DE FLUXO
    // Fill > 2.0 com fluxo zero por > 10 s → FAULT 1001
    //==========================================================
    s_FlowWatchdog(
        IN := (t_FillOut > 2.0) AND (i_FlowMeter < 0.1)
                AND ((s_State = 2) OR (s_State = 4)),
        PT := T#10S
    );
    IF s_FlowWatchdog.Q THEN
        s_FaultCode := 1001;
        s_State     := 98;
        t_FillOut   := 0.0;
        t_DrainOut  := 0.0;
    END_IF;

    //==========================================================
    // INTERLOCK: Fill > 5.0 + Drain > 0 simultaneamente → proibido
    //==========================================================
    IF (t_FillOut > 5.0) AND (t_DrainOut > 0.0) THEN
        t_DrainOut := 0.0;
    END_IF;

    //==========================================================
    // SEGURANÇA FINAL — backup E-Stop independente da FSM
    //==========================================================
    IF NOT i_EStop THEN
        t_FillOut  := 0.0;
        t_DrainOut := 0.0;
    END_IF;

    //==========================================================
    // ATRIBUIÇÃO DE OUTPUTS
    //==========================================================
    o_FillValve  := t_FillOut;
    o_DrainValve := t_DrainOut;
    o_State      := s_State;
    o_FaultCode  := s_FaultCode;
    o_IsRunning  := (s_State = 2) OR (s_State = 4);
    o_IsFault    := (s_State = 98) OR (s_State = 99);
    o_CycleCount := s_CycleCount;

    // Tempo decorrido em segundos (para display %QD38)
    IF (s_State = 4) AND (s_TimerPhase = 0) THEN
        o_TimerElapsed := TIME_TO_DINT(s_FillTimer.ET) / 1000;
    ELSIF (s_State = 4) AND (s_TimerPhase = 1) THEN
        o_TimerElapsed := TIME_TO_DINT(s_DrainTimer.ET) / 1000;
    ELSIF s_State = 1 THEN
        o_TimerElapsed := TIME_TO_DINT(s_StartingTimer.ET) / 1000;
    ELSE
        o_TimerElapsed := 0;
    END_IF;

END_FUNCTION_BLOCK
