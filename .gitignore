# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — IntelliJ Platform Plugin (Gradle + GrammarKit + JFlex)
# ─────────────────────────────────────────────────────────────────────────────

# ── Gradle build outputs ──────────────────────────────────────────────────────
build/
.gradle/
out/

# ── Generated sources (Grammar-Kit / JFlex) ───────────────────────────────────
# Regenerated by: ./gradlew generateSclParser generateSclLexer
src/main/gen/

# ── IntelliJ Platform sandbox (created by runIde) ────────────────────────────
.intellijPlatform/

# ── IntelliJ IDEA project files ───────────────────────────────────────────────
.idea/
!.idea/runConfigurations/
!.idea/codeStyles/
!.idea/codeStyleSettings.xml
*.iml
*.ipr
*.iws

# ── Gradle wrapper jar (scripts são versionados, binário não) ────────────────
gradle/wrapper/gradle-wrapper.jar

# ── Kotlin compiler caches ────────────────────────────────────────────────────
.kotlin/

# ── OS-specific ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Temporary / local files ───────────────────────────────────────────────────
*.class
*.log
*.tmp
*.bak
local.properties

# ── Distribution artifacts (plugin zip generated by buildPlugin) ──────────────
*.zip
dist/

# ── Siemens reference docs (PDFs — copyright material, arquivos grandes) ──────
docs/
examples/exemplo01.pdf

# ── Arquivos extraídos pelo runIde do IntelliJ SDK (não são código do plugin) ──
# Ancoragem com '/' = apenas no root do repositório
/META-INF/
/com/
/fileTemplates/
/generated-xmls/
/intellij.*.xml
/plugin.xml

# ── Documentos binários de projeto ───────────────────────────────────────────
*.docx
